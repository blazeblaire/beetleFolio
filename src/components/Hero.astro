---
// No props — content is stable identity data
---

<section
  id="hero"
  aria-labelledby="hero-heading"
  class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 pt-20 pb-24 sm:pt-28 sm:pb-32"
>
  <div class="max-w-2xl">

    <!-- Availability signal -->
    <div class="flex items-center gap-2 mb-7" aria-label="Currently available for work">
      <span class="relative flex h-2 w-2" aria-hidden="true">
        <span
          class="motion-safe:animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75"
        ></span>
        <span class="relative inline-flex rounded-full h-2 w-2 bg-emerald-500"></span>
      </span>
      <span class="text-sm font-medium text-emerald-700 dark:text-emerald-400">
        Available for remote &amp; freelance work
      </span>
    </div>

    <!-- Name -->
    <h1
      id="hero-heading"
      class="font-heading font-bold text-5xl sm:text-6xl lg:text-7xl
             text-zinc-900 dark:text-slate-50
             tracking-tight leading-[1.05]"
    >
      Tonny<br />Blaire
    </h1>

    <!-- Role -->
    <p
      class="mt-4 font-heading text-lg sm:text-xl
             text-zinc-500 dark:text-slate-400 font-medium tracking-tight"
    >
      Python-first Full Stack Engineer
    </p>

    <!-- Tagline -->
    <p
      class="mt-5 text-base sm:text-lg text-zinc-600 dark:text-slate-300
             leading-relaxed max-w-xl"
    >
      Building production backend APIs, full-stack web applications, and
      Docker-based systems — Python-first, security-aware.
    </p>

    <!-- Location -->
    <p
      class="mt-3 flex items-center gap-1.5
             text-sm text-zinc-400 dark:text-slate-500"
    >
      <svg
        aria-hidden="true"
        xmlns="http://www.w3.org/2000/svg"
        width="13"
        height="13"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
      >
        <path d="M20 10c0 4.993-5.539 10.193-7.399 11.799a1 1 0 0 1-1.202 0C9.539 20.193 4 14.993 4 10a8 8 0 0 1 16 0"/>
        <circle cx="12" cy="10" r="3"/>
      </svg>
      Eldoret, Kenya &mdash; Remote&thinsp;/&thinsp;Freelance&thinsp;/&thinsp;Project-based&thinsp;/&thinsp;Full-time remote
    </p>

    <!-- CTAs -->
    <div class="mt-9 flex flex-wrap items-center gap-3">
      <!-- Primary: View projects -->
      <a
        href="#projects"
        class="inline-flex items-center gap-2 px-5 py-3
               text-sm font-medium rounded-md
               bg-blue-600 text-white
               hover:bg-blue-700 dark:hover:bg-blue-500
               transition-colors duration-150 cursor-pointer"
      >
        View projects
        <svg
          aria-hidden="true"
          xmlns="http://www.w3.org/2000/svg"
          width="15"
          height="15"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2.5"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <path d="M5 12h14"/><path d="m12 5 7 7-7 7"/>
        </svg>
      </a>

      <!-- Secondary: Contact / hire -->
      <a
        href="#contact"
        class="inline-flex items-center px-5 py-3
               text-sm font-medium rounded-md
               border border-zinc-300 dark:border-slate-700
               text-zinc-700 dark:text-slate-300
               hover:bg-zinc-100 dark:hover:bg-slate-800
               transition-colors duration-150 cursor-pointer"
      >
        Available for remote/freelance work
      </a>

      <!-- Tertiary: Download CV -->
      <a
        href="/cv.pdf"
        download
        class="inline-flex items-center gap-1.5
               text-sm text-zinc-400 dark:text-slate-500
               hover:text-zinc-900 dark:hover:text-slate-50
               transition-colors duration-150 cursor-pointer"
        aria-label="Download Tonny Blaire's CV (PDF)"
      >
        <svg
          aria-hidden="true"
          xmlns="http://www.w3.org/2000/svg"
          width="14"
          height="14"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
          <polyline points="7 10 12 15 17 10"/>
          <line x1="12" x2="12" y1="15" y2="3"/>
        </svg>
        Download CV
      </a>
    </div>

  </div>
</section>
