---
/**
 * Contact section — static Formspree form + direct links.
 *
 * To activate the form:
 *  1. Create a free account at https://formspree.io
 *  2. Create a new form and copy the form ID (looks like "xyzabcde")
 *  3. Replace "YOUR_FORM_ID" in the action URL below.
 */
const FORMSPREE_ENDPOINT = "https://formspree.io/f/YOUR_FORM_ID";

const contactLinks = [
  {
    label: "Email",
    value: "blare9.70@gmail.com",
    href: "mailto:blare9.70@gmail.com",
    icon: `<svg aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>`,
  },
  {
    label: "GitHub",
    value: "github.com/blazeblaire",
    subtext: "125+ public repos",
    href: "https://github.com/blazeblaire",
    icon: `<svg aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0 1 12 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/></svg>`,
  },
  {
    label: "LinkedIn",
    value: "tonny-blaire",
    href: "https://linkedin.com/in/tonny-blaire-8392a629a",
    icon: `<svg aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>`,
  },
  {
    label: "Location",
    value: "Eldoret, Kenya",
    subtext: "Remote · Freelance · Contract",
    icon: `<svg aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 4.993-5.539 10.193-7.399 11.799a1 1 0 0 1-1.202 0C9.539 20.193 4 14.993 4 10a8 8 0 0 1 16 0"/><circle cx="12" cy="10" r="3"/></svg>`,
  },
] as const;
---

<section
  id="contact"
  aria-labelledby="contact-heading"
  class="border-t border-zinc-200 dark:border-slate-800"
>
  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-20">

    <!-- Section header -->
    <p
      aria-hidden="true"
      class="font-mono text-xs uppercase tracking-widest
             text-zinc-400 dark:text-slate-500 mb-3"
    >
      Contact
    </p>
    <h2
      id="contact-heading"
      class="font-heading text-2xl sm:text-3xl font-semibold
             text-zinc-900 dark:text-slate-50 mb-14"
    >
      Get in touch
    </h2>

    <div class="grid gap-14 lg:grid-cols-2">

      <!-- ── Left: info ──────────────────────────── -->
      <div>
        <p class="text-base text-zinc-600 dark:text-slate-300 leading-relaxed max-w-sm">
          Available for remote, freelance, and contract work. Open to full-time
          remote roles too. Drop a message or reach out directly.
        </p>

        <ul class="mt-10 space-y-6" aria-label="Contact links">
          {contactLinks.map(({ label, value, subtext, href, icon }) => (
            <li>
              {href ? (
                <a
                  href={href}
                  {...(href.startsWith("http")
                    ? { target: "_blank", rel: "noopener noreferrer" }
                    : {})}
                  class="group flex items-start gap-4"
                  aria-label={`${label}: ${value}${subtext ? ` — ${subtext}` : ""}`}
                >
                  <span
                    class="mt-0.5 shrink-0 text-zinc-400 dark:text-slate-500
                           group-hover:text-blue-500 dark:group-hover:text-blue-400
                           transition-colors duration-150"
                    set:html={icon}
                  />
                  <div>
                    <p class="text-xs font-mono uppercase tracking-wider
                               text-zinc-400 dark:text-slate-500 mb-0.5">
                      {label}
                    </p>
                    <p class="text-sm font-medium text-zinc-800 dark:text-slate-200
                               group-hover:text-blue-600 dark:group-hover:text-blue-400
                               transition-colors duration-150">
                      {value}
                    </p>
                    {subtext && (
                      <p class="text-xs text-zinc-400 dark:text-slate-500 mt-0.5">
                        {subtext}
                      </p>
                    )}
                  </div>
                </a>
              ) : (
                <div class="flex items-start gap-4">
                  <span
                    class="mt-0.5 shrink-0 text-zinc-400 dark:text-slate-500"
                    set:html={icon}
                  />
                  <div>
                    <p class="text-xs font-mono uppercase tracking-wider
                               text-zinc-400 dark:text-slate-500 mb-0.5">
                      {label}
                    </p>
                    <p class="text-sm font-medium text-zinc-800 dark:text-slate-200">
                      {value}
                    </p>
                    {subtext && (
                      <p class="text-xs text-zinc-400 dark:text-slate-500 mt-0.5">
                        {subtext}
                      </p>
                    )}
                  </div>
                </div>
              )}
            </li>
          ))}
        </ul>
      </div>

      <!-- ── Right: form ─────────────────────────── -->
      <div>
        <form
          id="contact-form"
          method="POST"
          action={FORMSPREE_ENDPOINT}
          novalidate
          class="flex flex-col gap-5"
          aria-label="Contact form"
        >
          <!-- Honeypot — hidden from humans, filled by bots -->
          <input
            type="text"
            name="_gotcha"
            tabindex="-1"
            autocomplete="off"
            class="hidden"
            aria-hidden="true"
          />
          <!-- Custom email subject -->
          <input
            type="hidden"
            name="_subject"
            value="Portfolio enquiry — Tonny Blaire"
          />

          <!-- Name -->
          <div class="flex flex-col gap-1.5">
            <label
              for="cf-name"
              class="text-xs font-mono uppercase tracking-wider
                     text-zinc-500 dark:text-slate-400"
            >
              Name <span aria-hidden="true" class="text-blue-500">*</span>
            </label>
            <input
              type="text"
              id="cf-name"
              name="name"
              required
              autocomplete="name"
              placeholder="Your name"
              class="w-full px-3 py-2.5 rounded-md text-sm
                     border border-zinc-300 dark:border-slate-700
                     bg-white dark:bg-slate-900
                     text-zinc-900 dark:text-slate-50
                     placeholder:text-zinc-400 dark:placeholder:text-slate-600
                     outline-none
                     focus-visible:ring-2 focus-visible:ring-blue-500
                     focus-visible:ring-offset-1 focus-visible:ring-offset-zinc-50
                     dark:focus-visible:ring-offset-slate-950
                     transition-colors duration-150"
            />
          </div>

          <!-- Email -->
          <div class="flex flex-col gap-1.5">
            <label
              for="cf-email"
              class="text-xs font-mono uppercase tracking-wider
                     text-zinc-500 dark:text-slate-400"
            >
              Email <span aria-hidden="true" class="text-blue-500">*</span>
            </label>
            <input
              type="email"
              id="cf-email"
              name="email"
              required
              autocomplete="email"
              placeholder="you@example.com"
              class="w-full px-3 py-2.5 rounded-md text-sm
                     border border-zinc-300 dark:border-slate-700
                     bg-white dark:bg-slate-900
                     text-zinc-900 dark:text-slate-50
                     placeholder:text-zinc-400 dark:placeholder:text-slate-600
                     outline-none
                     focus-visible:ring-2 focus-visible:ring-blue-500
                     focus-visible:ring-offset-1 focus-visible:ring-offset-zinc-50
                     dark:focus-visible:ring-offset-slate-950
                     transition-colors duration-150"
            />
          </div>

          <!-- Message -->
          <div class="flex flex-col gap-1.5">
            <label
              for="cf-message"
              class="text-xs font-mono uppercase tracking-wider
                     text-zinc-500 dark:text-slate-400"
            >
              Message <span aria-hidden="true" class="text-blue-500">*</span>
            </label>
            <textarea
              id="cf-message"
              name="message"
              required
              rows="5"
              placeholder="Tell me about the project or role…"
              class="w-full px-3 py-2.5 rounded-md text-sm resize-y
                     border border-zinc-300 dark:border-slate-700
                     bg-white dark:bg-slate-900
                     text-zinc-900 dark:text-slate-50
                     placeholder:text-zinc-400 dark:placeholder:text-slate-600
                     outline-none
                     focus-visible:ring-2 focus-visible:ring-blue-500
                     focus-visible:ring-offset-1 focus-visible:ring-offset-zinc-50
                     dark:focus-visible:ring-offset-slate-950
                     transition-colors duration-150"
            ></textarea>
          </div>

          <!-- Submit -->
          <button
            id="cf-submit"
            type="submit"
            class="inline-flex items-center justify-center gap-2
                   px-5 py-2.5 text-sm font-medium rounded-md
                   bg-blue-600 text-white
                   hover:bg-blue-700 dark:hover:bg-blue-500
                   disabled:opacity-50 disabled:cursor-not-allowed
                   transition-colors duration-150 cursor-pointer
                   self-start"
          >
            <span id="cf-btn-text">Send message</span>
            <svg
              id="cf-spinner"
              aria-hidden="true"
              class="hidden animate-spin"
              xmlns="http://www.w3.org/2000/svg"
              width="15"
              height="15"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2.5"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <path d="M21 12a9 9 0 1 1-6.219-8.56"/>
            </svg>
          </button>

          <!-- Status message (success / error) -->
          <p
            id="cf-status"
            role="alert"
            aria-live="polite"
            aria-atomic="true"
            class="hidden text-sm rounded-md px-3 py-2.5"
          ></p>
        </form>
      </div>

    </div>
  </div>
</section>

<script>
  const form     = document.getElementById("contact-form") as HTMLFormElement | null;
  const submitBtn = document.getElementById("cf-submit")    as HTMLButtonElement | null;
  const btnText  = document.getElementById("cf-btn-text");
  const spinner  = document.getElementById("cf-spinner");
  const status   = document.getElementById("cf-status");

  if (!form || !submitBtn || !btnText || !spinner || !status) {
    // Elements missing — fail silently (server render or test env)
  } else {
    function setLoading(loading: boolean) {
      submitBtn!.disabled = loading;
      btnText!.textContent = loading ? "Sending…" : "Send message";
      spinner!.classList.toggle("hidden", !loading);
    }

    function showStatus(message: string, ok: boolean) {
      status!.textContent = message;
      status!.className = [
        "text-sm rounded-md px-3 py-2.5",
        ok
          ? "bg-emerald-50 text-emerald-800 border border-emerald-200 dark:bg-emerald-950 dark:text-emerald-300 dark:border-emerald-800"
          : "bg-red-50 text-red-800 border border-red-200 dark:bg-red-950 dark:text-red-300 dark:border-red-800",
      ].join(" ");
      status!.classList.remove("hidden");
    }

    function validateForm(): string | null {
      const name    = (form!.querySelector("#cf-name")    as HTMLInputElement)?.value.trim();
      const email   = (form!.querySelector("#cf-email")   as HTMLInputElement)?.value.trim();
      const message = (form!.querySelector("#cf-message") as HTMLTextAreaElement)?.value.trim();

      if (!name)    return "Please enter your name.";
      if (!email || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email))
                    return "Please enter a valid email address.";
      if (!message) return "Please write a message.";
      return null;
    }

    form.addEventListener("submit", async (e) => {
      e.preventDefault();
      status!.classList.add("hidden");

      const validationError = validateForm();
      if (validationError) {
        showStatus(validationError, false);
        // Move focus to the first invalid field
        const firstInvalid = form!.querySelector(":invalid") as HTMLElement | null;
        firstInvalid?.focus();
        return;
      }

      setLoading(true);

      try {
        const res = await fetch(form!.action, {
          method: "POST",
          body: new FormData(form!),
          headers: { Accept: "application/json" },
        });

        if (res.ok) {
          form!.reset();
          showStatus("Message sent — I'll get back to you soon.", true);
        } else {
          const data = await res.json().catch(() => ({}));
          const msg =
            Array.isArray(data.errors)
              ? data.errors.map((err: { message: string }) => err.message).join(", ")
              : "Something went wrong. Email me directly at blare9.70@gmail.com.";
          showStatus(msg, false);
        }
      } catch {
        showStatus(
          "Could not send — check your connection or email blare9.70@gmail.com directly.",
          false
        );
      } finally {
        setLoading(false);
      }
    });
  }
</script>
