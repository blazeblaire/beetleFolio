---
const navLinks = [
  { href: "#about", label: "About" },
  { href: "#projects", label: "Projects" },
  { href: "#experience", label: "Experience" },
  { href: "#contact", label: "Contact" },
] as const;
---

<header
  class="sticky top-0 z-40 w-full border-b border-zinc-200 dark:border-slate-800 bg-zinc-50/90 dark:bg-slate-950/90 backdrop-blur-sm"
>
  <div
    class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 flex items-center justify-between h-14"
  >
    <!-- Logo / Name -->
    <a href="/" class="flex items-center gap-2.5 group" aria-label="Tonny Blaire — home">
      <span
        class="font-heading font-semibold text-zinc-900 dark:text-slate-50 text-sm tracking-tight"
      >
        Tonny Blaire
      </span>
      <span
        class="hidden sm:inline-flex items-center gap-1 px-2 py-0.5 text-xs font-medium rounded-full border
               bg-emerald-50 text-emerald-700 border-emerald-200
               dark:bg-emerald-950 dark:text-emerald-400 dark:border-emerald-800"
      >
        <span class="relative flex h-1.5 w-1.5" aria-hidden="true">
          <span
            class="motion-safe:animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75"
          ></span>
          <span
            class="relative inline-flex rounded-full h-1.5 w-1.5 bg-emerald-500"
          ></span>
        </span>
        Available
      </span>
    </a>

    <!-- Desktop nav -->
    <nav aria-label="Main navigation" class="hidden md:flex items-center gap-6">
      {
        navLinks.map(({ href, label }) => (
          <a
            href={href}
            class="text-sm text-zinc-500 dark:text-slate-400 hover:text-zinc-900 dark:hover:text-slate-50 transition-colors duration-150 cursor-pointer"
          >
            {label}
          </a>
        ))
      }
    </nav>

    <!-- Right controls -->
    <div class="flex items-center gap-1">
      <!-- Dark mode toggle -->
      <button
        id="theme-toggle"
        type="button"
        aria-label="Toggle dark mode"
        class="inline-flex items-center justify-center min-h-11 min-w-11 p-2.5 rounded-md text-zinc-500 dark:text-slate-400
               hover:text-zinc-900 dark:hover:text-slate-50
               hover:bg-zinc-100 dark:hover:bg-slate-800
               transition-colors duration-150 cursor-pointer"
      >
        <!-- Sun (visible in dark mode) -->
        <svg
          aria-hidden="true"
          class="hidden dark:block"
          xmlns="http://www.w3.org/2000/svg"
          width="18"
          height="18"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <circle cx="12" cy="12" r="4"></circle>
          <path d="M12 2v2"></path><path d="M12 20v2"></path>
          <path d="m4.93 4.93 1.41 1.41"></path>
          <path d="m17.66 17.66 1.41 1.41"></path>
          <path d="M2 12h2"></path><path d="M20 12h2"></path>
          <path d="m6.34 17.66-1.41 1.41"></path>
          <path d="m19.07 4.93-1.41 1.41"></path>
        </svg>
        <!-- Moon (visible in light mode) -->
        <svg
          aria-hidden="true"
          class="block dark:hidden"
          xmlns="http://www.w3.org/2000/svg"
          width="18"
          height="18"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"></path>
        </svg>
      </button>

      <!-- Mobile hamburger -->
      <button
        id="mobile-menu-btn"
        type="button"
        aria-label="Open navigation menu"
        aria-expanded="false"
        aria-controls="mobile-menu"
        class="md:hidden inline-flex items-center justify-center min-h-11 min-w-11 p-2.5 rounded-md text-zinc-500 dark:text-slate-400
               hover:text-zinc-900 dark:hover:text-slate-50
               hover:bg-zinc-100 dark:hover:bg-slate-800
               transition-colors duration-150 cursor-pointer"
      >
        <!-- Hamburger -->
        <svg
          id="icon-menu"
          aria-hidden="true"
          xmlns="http://www.w3.org/2000/svg"
          width="20"
          height="20"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <line x1="4" x2="20" y1="6" y2="6"></line>
          <line x1="4" x2="20" y1="12" y2="12"></line>
          <line x1="4" x2="20" y1="18" y2="18"></line>
        </svg>
        <!-- Close -->
        <svg
          id="icon-close"
          aria-hidden="true"
          class="hidden"
          xmlns="http://www.w3.org/2000/svg"
          width="20"
          height="20"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <path d="M18 6 6 18"></path>
          <path d="m6 6 12 12"></path>
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile menu panel -->
  <div
    id="mobile-menu"
    class="hidden md:hidden border-t border-zinc-200 dark:border-slate-800"
    role="navigation"
    aria-label="Mobile navigation"
  >
    <nav class="max-w-5xl mx-auto px-4 py-3 flex flex-col gap-1">
      {
        navLinks.map(({ href, label }) => (
          <a
            href={href}
            class="py-3 px-3 text-sm text-zinc-600 dark:text-slate-400
                   hover:text-zinc-900 dark:hover:text-slate-50
                   hover:bg-zinc-100 dark:hover:bg-slate-800
                   rounded transition-colors duration-150"
          >
            {label}
          </a>
        ))
      }
    </nav>
  </div>
</header>

<script>
  // ── Dark mode toggle ──────────────────────────────────────────────────────
  document.getElementById("theme-toggle")?.addEventListener("click", () => {
    const isDark = document.documentElement.classList.toggle("dark");
    localStorage.setItem("theme", isDark ? "dark" : "light");
  });

  // ── Mobile menu ───────────────────────────────────────────────────────────
  const menuBtn = document.getElementById("mobile-menu-btn");
  const mobileMenu = document.getElementById("mobile-menu");
  const iconMenu = document.getElementById("icon-menu");
  const iconClose = document.getElementById("icon-close");

  function openMenu() {
    mobileMenu?.classList.remove("hidden");
    menuBtn?.setAttribute("aria-expanded", "true");
    iconMenu?.classList.add("hidden");
    iconClose?.classList.remove("hidden");
  }

  function closeMenu() {
    mobileMenu?.classList.add("hidden");
    menuBtn?.setAttribute("aria-expanded", "false");
    iconMenu?.classList.remove("hidden");
    iconClose?.classList.add("hidden");
  }

  menuBtn?.addEventListener("click", () => {
    const isOpen = mobileMenu?.classList.contains("hidden") === false;
    isOpen ? closeMenu() : openMenu();
  });

  // Close when a nav link is tapped
  mobileMenu?.querySelectorAll("a").forEach((link) => {
    link.addEventListener("click", closeMenu);
  });
</script>
