---
import type { Project } from "../data/projects";

interface Props {
  project: Project;
}

const { project } = Astro.props;
const { title, year, description, tags, repo, demo, highlights } = project;
---

<article
  class="group flex flex-col gap-4 rounded-lg
         border border-zinc-200 dark:border-slate-800
         bg-white dark:bg-slate-900/50
         p-6
         hover:border-zinc-300 dark:hover:border-slate-700
         hover:shadow-sm
         focus-within:ring-2 focus-within:ring-blue-600
         focus-within:ring-offset-2 focus-within:ring-offset-zinc-50
         dark:focus-within:ring-blue-400 dark:focus-within:ring-offset-slate-950
         transition-all duration-150"
>

  <!-- Header: year + server-side badge (when no demo) -->
  <div class="flex items-center justify-between gap-2">
    <span class="font-mono text-xs text-zinc-500 dark:text-slate-400">
      {year}
    </span>
    {
      !demo && (
        <span
          class="font-mono text-[0.65rem] leading-none
                 px-1.5 py-1 rounded
                 border border-zinc-200 dark:border-slate-700
                 text-zinc-500 dark:text-slate-400"
          title="No live demo — server-side or hardware project"
        >
          server-side
        </span>
      )
    }
  </div>

  <!-- Title -->
  <h3
    class="font-heading font-semibold text-base leading-snug
           text-zinc-900 dark:text-slate-50 -mt-1"
  >
    {title}
  </h3>

  <!-- Description -->
  <p class="text-sm text-zinc-600 dark:text-slate-400 leading-relaxed">
    {description}
  </p>

  <!-- Tech tags -->
  <div class="flex flex-wrap gap-1.5" aria-label="Technologies">
    {
      tags.map((tag) => (
        <span
          class="inline-block px-2 py-0.5 text-[0.7rem] leading-5 rounded
                 border border-zinc-200 dark:border-slate-700
                 bg-zinc-50 dark:bg-slate-800
                 text-zinc-600 dark:text-slate-300
                 font-mono"
        >
          {tag}
        </span>
      ))
    }
  </div>

  <!-- Highlights -->
  <ul class="space-y-2" aria-label="Highlights">
    {
      highlights.map((h) => (
        <li class="flex gap-2 text-sm text-zinc-600 dark:text-slate-400 leading-relaxed">
          <span
            aria-hidden="true"
            class="mt-0.5 shrink-0 font-mono text-blue-500 dark:text-blue-400 select-none"
          >
            →
          </span>
          {h}
        </li>
      ))
    }
  </ul>

  <!-- Footer: action links — pushed to bottom of card -->
  <footer
    class="mt-auto flex items-center gap-5 pt-4
           border-t border-zinc-100 dark:border-slate-800"
  >
    <!-- GitHub -->
    <a
      href={repo}
      target="_blank"
      rel="noopener noreferrer"
      class="flex items-center gap-1.5 text-xs font-medium
             text-zinc-500 dark:text-slate-400
             hover:text-zinc-900 dark:hover:text-slate-50
             transition-colors duration-150"
      aria-label={`View ${title} source code on GitHub (opens in new tab)`}
    >
      <svg
        aria-hidden="true"
        xmlns="http://www.w3.org/2000/svg"
        width="14"
        height="14"
        viewBox="0 0 24 24"
        fill="currentColor"
      >
        <path
          d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0 1 12 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"
        ></path>
      </svg>
      View on GitHub
    </a>

    <!-- Live demo (only rendered when demo URL exists) -->
    {
      demo && (
        <a
          href={demo}
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center gap-1.5 text-xs font-medium
                 text-zinc-500 dark:text-slate-400
                 hover:text-zinc-900 dark:hover:text-slate-50
                 transition-colors duration-150"
          aria-label={`Open live demo of ${title} (opens in new tab)`}
        >
          <svg
            aria-hidden="true"
            xmlns="http://www.w3.org/2000/svg"
            width="13"
            height="13"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <path d="M15 3h6v6" />
            <path d="M10 14 21 3" />
            <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6" />
          </svg>
          Live demo
        </a>
      )
    }
  </footer>
</article>
